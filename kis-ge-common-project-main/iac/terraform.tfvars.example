# Copy to terraform.tfvars (gitignored).
#
# 본 stack은 KRInvest GCP 조직 전체에 영향을 미치는 자원만 다룬다.
# 자회사별 자원(Discovery Engine, IAM bindings, KMS, ...)은 별도 자회사 stack
# (kis-ge-project, kih-ge-project, ...)에서 관리한다.

# === Org identity ===
org_id          = "240369219899"
billing_project = "kis-gemini-common-prod"
region_primary  = "asia-northeast3"

# === Phase 1-A: Access Context Manager Access Policy ===
access_policy_title = "krinvest-lzone-policy"

# === Phase 1-B: Central Service Perimeter (모든 자회사 통합) ===
# 자회사 stack에서 perimeter를 만들지 않고 본 stack이 단독 관리.
# 자회사 stack apply 후 subsidiary_project_ids에 새 프로젝트 추가하고 재 apply.
enable_central_perimeter = false
perimeter_dry_run        = true
subsidiary_project_ids   = []
# 예시:
# subsidiary_project_ids = [
#   "kis-gemini-enterprise",
#   "kih-gemini-enterprise",
# ]
perimeter_allowed_ip_ranges       = []
perimeter_allowed_members         = ["user:snswang@mz.co.kr"]
perimeter_ingress_identities      = ["user:snswang@mz.co.kr"]
perimeter_ingress_source_projects = []
perimeter_restricted_services = [
  "aiplatform.googleapis.com",
  "storage.googleapis.com",
  "bigquery.googleapis.com",
  "dlp.googleapis.com",
  "cloudkms.googleapis.com",
]

# === Phase 2: Storage Org Policies (안전, 기본 활성) ===
enforce_public_access_prevention    = true
enforce_uniform_bucket_level_access = true

# === Phase 2: CMEK Org Policies (자회사 KMS 준비 후 활성화) ===
enable_restrict_non_cmek = false
cmek_required_services = [
  "bigquery.googleapis.com",
  "storage.googleapis.com",
  "discoveryengine.googleapis.com",
  "aiplatform.googleapis.com",
]

# === Phase 3: Aggregated Log Sink ===
ops_project_id            = "kis-gemini-common-prod"
central_audit_bucket_name = "kis-gemini-common-prod-org-audit-logs"
retention_days            = 2555
lock_retention            = false
aggregated_sink_name      = "krinvest-org-audit-to-gcs"

# === Phase 3: Org IAM AuditConfig (비용 영향, 사전 검토 후 활성화) ===
enable_org_data_access_audit = false

# === DLP Discovery (조직 레벨, SCC Premium + 비용 영향 큼) ===
# SCC Premium tier 활성화 + SA에 roles/dlp.organizationsAdmin 부여 후 enable=true.
#
# KIS 환경 적용 정책:
#   - BigQuery       : 로그성 데이터, PII 분류 대상 아님 → false
#   - Cloud Storage  : 로그성 데이터, PII 분류 대상 아님 → false
#   - Cloud SQL      : 미사용 → false
# 모든 scan_targets 가 false 면 enable_dlp_discovery=true 여도 자원 0개.
# 추후 PII 가능성 있는 자원 도입 시 해당 type 만 true 로.
enable_dlp_discovery = false
dlp_scan_targets = {
  bigquery      = false  # 로그성, PII 없음
  cloud_storage = false  # 로그성, PII 없음
  cloud_sql     = false  # 미사용
}
dlp_cadence_frequency           = "UPDATE_FREQUENCY_MONTHLY"  # DAILY가 더 비쌈
dlp_subsidiary_project_id_regex = ".*-(kis|kih)$"

# === Phase 4-A: Location Restrictions (한국 데이터 주권) ===
enable_resource_locations = true
allowed_locations = [
  "in:asia-northeast3-locations", # 서울 region
  "in:asia-locations",            # asia multi-region (DLP us 예외 포함되려면 in:us-locations 추가)
]

# === Phase 4-B: Service Usage Restriction (API 화이트리스트) ===
# allowed_services는 variables.tf default가 KRInvest GE stack에 맞게 정의됨.
# 새 API 추가 필요 시 여기서 override.
enable_restrict_service_usage = true
# allowed_services = [ ... ]   # default 사용

# === Phase 4-C: IAM Policies (SA 보안) ===
disable_service_account_key_creation        = true
disable_cross_project_service_account_usage = true
disable_automatic_iam_grants_default_sa     = true

# === Phase 5: Domain Restriction (⚠️ mz.co.kr lock 위험) ===
# 활성화 전:
#   1. gcloud organizations list 로 customer ID 확인 (C0xxxxxx 형식)
#   2. KRInvest 운영자 도메인 customer ID 모두 수집
#   3. mz.co.kr 외부 작업자가 권한 정리 (또는 mz.co.kr customer ID 임시 포함)
#   4. allowed_member_domains 채우고 enable_domain_restriction = true
#   5. CI는 plan-only stage만 제공 → 결과 확인 후 별도 수동 apply
enable_domain_restriction = false
allowed_member_domains    = []
# 예시:
# allowed_member_domains = [
#   "C0abc1234",  # koreainvestment.com customer ID
#   "C0xyz5678",  # mz.co.kr customer ID (작업 종료 후 제거)
# ]

# === Phase 6: SCC Premium 자원 ===
# 활성화 전:
#   1. GCP Console > Security > Security Command Center > Settings
#   2. Tier > Premium 또는 Enterprise 활성화 (billing 권한 있는 사용자 작업)
#   3. CI의 enable-scc-tier 게이트 통과
#   4. enable_phase6 = true 로 변경하고 main에 push
enable_phase6                = false
scc_notification_topic_name  = "scc-findings-notifications"
scc_notification_config_id   = "all-active-findings"
scc_notification_filter      = "state=\"ACTIVE\" AND severity IN [\"HIGH\", \"CRITICAL\"]"

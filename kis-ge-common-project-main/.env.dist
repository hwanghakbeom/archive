# Sample env file. Copy to .env (gitignored) for local development only.
# In CI these come from GitLab CI variables — NOT from this file.

GCP_ORG_ID=240369219899

# Terraform state backend (lives in kis-common-gcp ops project)
TF_STATE_BUCKET=kis-common-gcp-tfstate
TF_STATE_PREFIX=lzone/org

# Cloud Build project that runs the pipeline (same ops project)
GCP_TF_PROJECT=kis-common-gcp

# Org-level admin SA JSON key (local only; CI uses Workload Identity Federation)
GCP_TF_SA_KEY=
